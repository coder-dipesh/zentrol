# LTI local testing overrides.
# Merge these into your .env before running the Moodle integration test.
#
# host.docker.internal = your Mac, reachable from inside Docker
# Django must be started with:  python manage.py runserver 0.0.0.0:8000

ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal,.ngrok-free.app
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://host.docker.internal:8000,http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://host.docker.internal:8000

# Cache: use DB cache so LTI OIDC state survives across requests
CACHE_BACKEND=django.core.cache.backends.db.DatabaseCache
CACHE_LOCATION=zentrol_cache_table

# Tell Zentrol what URL Moodle will call for the LTI endpoints.
# Moodle (Docker) reaches Django via host.docker.internal:8000.
LTI_BASE_URL=http://host.docker.internal:8000
