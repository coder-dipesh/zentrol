# Copy to `.env` and adjust. Never commit real secrets.
#
# Django
SECRET_KEY=change-me-in-development-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — SQLite (default) or PostgreSQL (recommended for parity with production)
DATABASE_URL=sqlite:///db.sqlite3
# With docker-compose Postgres (see docs/DEPLOYMENT.md):
# DATABASE_URL=postgres://zentrol:zentrol@127.0.0.1:5432/zentrol

# CORS / CSRF — same-origin is typical (Django serves HTML + /static + /api).
# Add extra origins if you embed the API from another host.
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional production hardening (when DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# LOG_LEVEL=INFO

# Serverless / legacy (full Django on Vercel — not recommended for production DB)
# VERCEL=1

# Lip2Speech — pre-trained weights (265 MB).
# Download: https://www.mediafire.com/file/evktjxytts2t72c/lip2speech_final.pth/file
# Place at lip2speech/weights/lip2speech_final.pth  (default, no env var needed)
# Or override the path here:
# LIP2SPEECH_WEIGHTS_PATH=/absolute/path/to/lip2speech_final.pth

# Optional: require POST /api/log-gesture/ to send X-Zentrol-Gesture-Log-Secret
# GESTURE_LOG_SHARED_SECRET=

# Expose /api/docs and /api/schema when DEBUG=False (default off)
# SPECTACULAR_PUBLIC=False

# ── Moodle / LTI 1.3 ─────────────────────────────────────────────────────────
# Cache backend — PyLTI1p3 stores OIDC state/nonces in Django's cache.
# Default: DatabaseCache (requires: python manage.py createcachetable)
# For production with Redis (pip install django-redis):
# CACHE_BACKEND=django_redis.cache.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/1
CACHE_BACKEND=django.core.cache.backends.db.DatabaseCache
CACHE_LOCATION=zentrol_cache_table

# Public base URL of this Zentrol deployment (used in LTI config JSON).
# Set to your public domain in production, e.g. https://zentrol.example.com
LTI_BASE_URL=http://localhost:8000

# ── Setup checklist ───────────────────────────────────────────────────────────
# 1. pip install PyLTI1p3 cryptography
# 2. python manage.py migrate                    (creates moodle tables)
# 3. python manage.py createcachetable           (creates LTI OIDC state cache)
# 4. python manage.py generate_lti_keys \
#       --name "My Moodle" \
#       --issuer https://moodle.example.com \
#       --client-id <from Moodle>  \
#       --auth-login-url https://moodle.example.com/mod/lti/auth.php \
#       --auth-token-url https://moodle.example.com/mod/lti/token.php \
#       --key-set-url   https://moodle.example.com/mod/lti/certs.php
# 5. In Moodle: Site admin → External tools → Add tool
#       Tool URL: https://<zentrol-host>/moodle/lti/config/
